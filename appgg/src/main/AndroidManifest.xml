<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="nostalgia.appgg">

    <application
        android:name=".GGApplication"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/AppTheme">

        <activity
            android:name=".GGGalleryActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/AppTheme.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <action android:name="nostalgia.gg.GALLERY" />

                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            
            <!-- File opening intent-filter -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/octet-stream" />
                <data android:mimeType="application/x-gg-rom" />
                <data android:mimeType="application/x-sms-rom" />
                <data android:scheme="file" />
                <data android:scheme="content" />
                <data android:host="*" />
                <data android:pathPattern=".*\\.gg" />
                <data android:pathPattern=".*\\.GG" />
                <data android:pathPattern=".*\\.sms" />
                <data android:pathPattern=".*\\.SMS" />
                <data android:pathPattern=".*\\.zip" />
                <data android:pathPattern=".*\\.ZIP" />
            </intent-filter>
            
            <!-- File sharing intent-filter -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/octet-stream" />
                <data android:mimeType="application/zip" />
                <data android:mimeType="application/x-zip-compressed" />
            </intent-filter>
        </activity>

        <activity
            android:name=".GGEmulatorActivity"
            android:launchMode="singleTask"
            android:theme="@style/AppTheme.FullScreen" />
        <activity
            android:name="nostalgia.framework.ui.preferences.GeneralPreferenceActivity"
            android:exported="true"
            android:label="@string/general_pref"
            android:theme="@style/PrefTheme">
            <intent-filter>
                <action android:name="nostalgia.gg.GENERALPREF" />

                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <activity
            android:name="nostalgia.framework.ui.preferences.KeyboardSettingsActivity"
            android:exported="true"
            android:label="@string/key_pref"
            android:theme="@style/PrefTheme">
            <intent-filter>
                <action android:name="nostalgia.gg.KEYBOARDPREF" />

                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <activity
            android:name="nostalgia.framework.ui.preferences.TouchControllerSettingsActivity"
            android:exported="true"
            android:label="@string/game_pref"
            android:theme="@style/AppTheme.FullScreen">
            <intent-filter>
                <action android:name="nostalgia.gg.TOUCHPREF" />

                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <activity
            android:name="nostalgia.framework.ui.preferences.ScreenViewPortSettingsActivity"
            android:exported="true"
            android:label="@string/game_pref"
            android:theme="@style/AppTheme.FullScreen">
            <intent-filter>
                <action android:name="nostalgia.gg.SCREENPREF" />

                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
    </application>
</manifest>
